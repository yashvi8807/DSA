//Problem: Rotate Linked List Right by k Places - Implement using linked list with dynamic memory allocation.

Input:
- First line: integer n
- Second line: n space-separated integers
- Third line: integer k

Output:
- Print the linked list elements after rotation, space-separated

Example:
Input:
5
10 20 30 40 50
2

Output:
40 50 10 20 30

Explanation:
Connect last node to head forming circular list. Traverse to (n-k)th node, set next to NULL, update head to (n-k+1)th node.


Code:
#include<stdio.h>
#include<stdlib.h>

struct Node{
    int data;
    struct Node* next;
};

int main(){
    int n,i,val,k,len=1;
    struct Node *head=NULL,*tail=NULL,*newNode,*temp;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter elements: ");
    for(i=0;i<n;i++){
        scanf("%d",&val);
        newNode=(struct Node*)malloc(sizeof(struct Node));
        newNode->data=val;
        newNode->next=NULL;

        if(head==NULL){
            head=newNode;
            tail=newNode;
        }else{
            tail->next=newNode;
            tail=newNode;
        }
    }

    printf("Enter k: ");
    scanf("%d",&k);

    if(head==NULL || head->next==NULL || k==0){
        temp=head;
        while(temp!=NULL){
            printf("%d ",temp->data);
            temp=temp->next;
        }
        return 0;
    }

    temp=head;
    while(temp->next!=NULL){
        temp=temp->next;
        len++;
    }

    temp->next=head;

    k=k%len;
    int steps=len-k;

    temp=head;
    for(i=1;i<steps;i++)
        temp=temp->next;

    head=temp->next;
    temp->next=NULL;

    printf("Rotated List: ");
    temp=head;
    while(temp!=NULL){
        printf("%d ",temp->data);
        temp=temp->next;
    }

    return 0;
}
